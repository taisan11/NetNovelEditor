{
	"name": "netnoveleditor",
	// "main": "dist/_worker.js/index.js",
	"compatibility_date": "2026-05-01",
	"assets": {
		"directory": "./dist",
		"not_found_handling": "single-page-application"
	},
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "nne.taisan11.dev",
			"custom_domain": true
		}
	],
}
